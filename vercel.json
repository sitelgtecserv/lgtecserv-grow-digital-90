{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/servicos/eletricidade-industrial",
      "destination": "/servicos/eletricidade-industrial-instalacoes-empresariais-mocambique",
      "permanent": true
    },
    {
      "source": "/servicos/ensaios-fotograficos",
      "destination": "/servicos/ensaios-fotograficos-profissionais-sem-studio-mocambique",
      "permanent": true
    },
    {
      "source": "/loja",
      "has": [
        {
          "type": "query",
          "key": "categoria"
        }
      ],
      "destination": "/loja/:categoria",
      "permanent": true
    },
    { "source": "/equipe/luis-martins", "destination": "/luismatsenjua", "permanent": true },
    { "source": "/equipe/inacio-langa", "destination": "/inaciolanga", "permanent": true },
    { "source": "/equipe/felix-florindo", "destination": "/felexlourindo", "permanent": true },
    { "source": "/equipe/lemos-sabado", "destination": "/lemossabado", "permanent": true },
    { "source": "/equipe/claudia-muale", "destination": "/claudiaarmando", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|svg|woff|woff2|ttf|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}